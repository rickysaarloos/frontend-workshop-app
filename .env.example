# Kopieer dit bestand naar .env en vul de juiste backend-URL in.
# Gebruik bij voorkeur https zodat het bearer-token niet onversleuteld over de lijn gaat.
# LET OP: vul de base URL in ZONDER /api-suffix. De code voegt /api zelf toe
# (bv. `${API_URL}/api/login`), dus VITE_API_URL=https://host:poort volstaat.
VITE_API_URL=https://jouw-backend-url
